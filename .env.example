# ---- Environment ----
ENV=local

# ---- Postgres ----
POSTGRES_USER=bos
POSTGRES_PASSWORD=bos
POSTGRES_DB=bos
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://bos:bos@postgres:5432/bos

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- Embeddings ----
# EMBEDDING_PROVIDER: ollama (local, free) | openai
EMBEDDING_PROVIDER=ollama
OLLAMA_URL=http://ollama:11434
# nomic-embed-text=768 | bge-m3=1024 | text-embedding-3-large=1536
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# ---- OpenAI ----
OPENAI_API_KEY=sk-replace-me
EXTRACTION_MODEL=gpt-4o-mini
SYNTHESIS_MODEL=gpt-4o

# ---- Connector API keys (optional; raise rate limits) ----
SEMANTIC_SCHOLAR_API_KEY=
PATENTSVIEW_API_KEY=

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
JWT_SECRET=dev-secret-change-me
CORS_ORIGINS=http://localhost:3000

# ---- Web ----
NEXT_PUBLIC_API_URL=http://localhost:8000
